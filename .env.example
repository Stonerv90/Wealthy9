# ─────────────────────────────────────────────────────────────
#  Wealthy9 AI Receptionist — Environment Variables
# ─────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  Never commit your .env file to git.
# ─────────────────────────────────────────────────────────────

# Anthropic API (required)
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Twilio — Phone Call Handling (required for voice) ───────
# Get these at: https://console.twilio.com
# Set your Twilio number's Voice webhook to: https://your-server.com/api/voice
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+13050000000

# ─── Email Notifications (optional but recommended) ──────────
# Sends audit request alerts to contact@wealthy9.com
# and confirmation emails to prospects.
# For Gmail: use an App Password (not your regular password)
# https://support.google.com/accounts/answer/185833
EMAIL_SERVICE=gmail
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_app_password_here
NOTIFY_EMAIL=contact@wealthy9.com

# ─── Server ──────────────────────────────────────────────────
PORT=3000

# Set to your website domain to restrict CORS
ALLOWED_ORIGIN=https://wealthy9.com
